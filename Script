local HttpGet = game.HttpGet

local WindUI
do
    local ok, result = pcall(function()
        return loadstring(HttpGet(game,"https://raw.githubusercontent.com/Footagesus/WindUI/main/dist/main.lua"))()
    end)

    if ok then
        WindUI = result
    end
end

local id = game.PlaceId or game.GameId
local url = "https://block-mender-api.vercel.app/api/load?id=" .. id

local ok, err = pcall(function()
    local code = HttpGet(game, url)

    if not code or code == "" then
        error("Empty response")
    end

    loadstring(code)()
end)

if not ok then
    warn("Loader failed:", err)

    if WindUI and WindUI.Notify then
        WindUI:Notify({
            Title = "Error",
            Content = tostring(err),
            Duration = 5,
            Icon = "warning"
        })
    end
end